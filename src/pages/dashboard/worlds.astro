---
import DashboardShell from "../../components/DashboardShell.astro";
---

<DashboardShell title="Kelola World | Bedrock Dashboard" activePath="/dashboard/worlds">
  <section class="space-y-6">
    <div id="feedback" class="hidden rounded-xl border border-[#2A2A2A] bg-[#1A1A1A] px-4 py-3 text-sm"></div>

    <article class="rounded-2xl border border-[#2A2A2A] bg-[#1A1A1A] p-5 sm:p-6">
      <h2 class="text-lg font-semibold text-[#FFFFFF]">Upload World</h2>
      <p class="mt-1 text-sm text-[#A0A0A0]">Format yang didukung: .mcworld</p>

      <form id="world-upload-form" class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center">
        <input
          id="world-file"
          type="file"
          accept=".mcworld"
          class="w-full min-w-0 flex-1 rounded-xl border border-[#2A2A2A] bg-[#0A0A0A] px-3 py-3 text-sm text-[#A0A0A0] file:mr-3 file:rounded-lg file:border-0 file:bg-[#2A2A2A] file:px-3 file:py-2 file:text-xs file:font-semibold file:text-[#F5F5F5]"
        />
        <button
          type="submit"
          class="h-12 shrink-0 whitespace-nowrap rounded-xl bg-[#F5F0E8] px-5 text-sm font-semibold text-[#0A0A0A] transition hover:bg-[#E8E0D0] sm:min-w-[9.5rem]"
          >Upload World</button
        >
      </form>
    </article>

    <article class="rounded-2xl border border-[#2A2A2A] bg-[#1A1A1A] p-5 sm:p-6">
      <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-[#666666]">Daftar World</h3>
      <div class="mt-4 overflow-x-auto rounded-xl border border-[#2A2A2A]">
        <table class="min-w-full divide-y divide-[#2A2A2A] text-left text-sm">
          <thead class="bg-[#111111] text-[#A0A0A0]">
            <tr>
              <th class="px-4 py-3">Nama World</th>
              <th class="px-4 py-3">Status</th>
              <th class="px-4 py-3">Aksi</th>
            </tr>
          </thead>
          <tbody id="world-table-body" class="divide-y divide-[#2A2A2A] bg-[#0A0A0A]"></tbody>
        </table>
      </div>
    </article>
  </section>

  <script>
    const feedback = document.getElementById("feedback");
    const worldTableBody = document.getElementById("world-table-body");

    type FeedbackType = "info" | "success" | "error";
    type WorldItem = { name: string; active: boolean };

    function showFeedback(message: string, type: FeedbackType = "info") {
      if (!(feedback instanceof HTMLElement)) {
        return;
      }
      feedback.classList.remove("hidden", "text-[#A0A0A0]", "text-[#ff9e9e]", "text-[#F5F0E8]");
      feedback.classList.add(type === "error" ? "text-[#ff9e9e]" : type === "success" ? "text-[#F5F0E8]" : "text-[#A0A0A0]");
      feedback.textContent = message;
    }

    async function api<T>(url: string, options: RequestInit = {}): Promise<T> {
      const response = await fetch(url, options);
      const data = (await response.json()) as { message?: string } & T;
      if (!response.ok) {
        throw new Error(data.message || "Request gagal");
      }
      return data;
    }

    function renderWorlds(worlds: WorldItem[]) {
      if (!(worldTableBody instanceof HTMLElement)) {
        return;
      }
      worldTableBody.innerHTML = "";

      if (!worlds.length) {
        worldTableBody.innerHTML = '<tr><td colspan="3" class="px-4 py-4 text-center text-[#666666]">Belum ada world.</td></tr>';
        return;
      }

      for (const world of worlds) {
        const row = document.createElement("tr");
        row.className = "text-[#F5F5F5]";

        const activateDisabled = world.active ? "disabled" : "";
        const activateClass = world.active
          ? "rounded-lg border border-[#2A2A2A] bg-[#1A1A1A] px-3 py-1 text-xs font-semibold text-[#666666]"
          : "rounded-lg bg-[#F5F0E8] px-3 py-1 text-xs font-semibold text-[#0A0A0A] transition hover:bg-[#E8E0D0]";

        row.innerHTML = `
          <td class="px-4 py-3">${world.name}</td>
          <td class="px-4 py-3">${world.active ? "Aktif" : "Nonaktif"}</td>
          <td class="px-4 py-3">
            <div class="flex flex-wrap gap-2">
              <button data-action="activate" data-world="${world.name}" ${activateDisabled} class="${activateClass}">${world.active ? "Sedang Aktif" : "Pilih Jadi Aktif"}</button>
              <button data-action="delete" data-world="${world.name}" class="rounded-lg border border-[#444444] bg-[#2A2A2A] px-3 py-1 text-xs font-semibold text-[#F5F5F5] transition hover:bg-[#444444]">Hapus</button>
            </div>
          </td>
        `;

        row.querySelector('[data-action="activate"]')?.addEventListener("click", async () => {
          try {
            showFeedback("Mengaktifkan world...");
            const data = await api<{ worlds: WorldItem[] }>("/api/worlds", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ worldName: world.name }),
            });
            renderWorlds(data.worlds);
            showFeedback("World aktif berhasil diubah.", "success");
          } catch (error) {
            showFeedback(error instanceof Error ? error.message : "Request gagal", "error");
          }
        });

        row.querySelector('[data-action="delete"]')?.addEventListener("click", async () => {
          if (!window.confirm(`Hapus world ${world.name}?`)) {
            return;
          }

          try {
            showFeedback("Menghapus world...");
            const data = await api<{ worlds: WorldItem[] }>("/api/worlds", {
              method: "DELETE",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ worldName: world.name }),
            });
            renderWorlds(data.worlds);
            showFeedback("World berhasil dihapus.", "success");
          } catch (error) {
            showFeedback(error instanceof Error ? error.message : "Request gagal", "error");
          }
        });

        worldTableBody.appendChild(row);
      }
    }

    async function loadWorlds() {
      const data = await api<{ worlds: WorldItem[] }>("/api/worlds");
      renderWorlds(data.worlds);
    }

    document.getElementById("world-upload-form")?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const input = document.getElementById("world-file");
      if (!(input instanceof HTMLInputElement) || !input.files || !input.files[0]) {
        showFeedback("Pilih file .mcworld terlebih dahulu.", "error");
        return;
      }

      const form = new FormData();
      form.append("file", input.files[0]);

      try {
        showFeedback("Mengupload world...");
        await api<{ ok: boolean }>("/api/worlds", {
          method: "POST",
          body: form,
        });
        input.value = "";
        await loadWorlds();
        showFeedback("Upload world berhasil.", "success");
      } catch (error) {
        showFeedback(error instanceof Error ? error.message : "Request gagal", "error");
      }
    });

    loadWorlds().catch((error) => {
      showFeedback(error instanceof Error ? error.message : "Request gagal", "error");
    });
  </script>
</DashboardShell>
