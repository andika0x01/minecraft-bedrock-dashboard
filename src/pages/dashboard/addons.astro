---
import DashboardShell from "../../components/DashboardShell.astro";
---

<DashboardShell title="Kelola Addon | Bedrock Dashboard" activePath="/dashboard/addons">
  <section class="space-y-6">
    <div id="feedback" class="hidden rounded-xl border border-[#2A2A2A] bg-[#1A1A1A] px-4 py-3 text-sm"></div>

    <article class="rounded-2xl border border-[#2A2A2A] bg-[#1A1A1A] p-5 sm:p-6">
      <h2 class="text-lg font-semibold text-[#FFFFFF]">Upload Addon</h2>
      <p class="mt-1 text-sm text-[#A0A0A0]">Format yang didukung: .mcpack, .mcaddon</p>

      <form id="pack-upload-form" class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center">
        <input
          id="pack-file"
          type="file"
          accept=".mcpack,.mcaddon"
          class="w-full min-w-0 flex-1 rounded-xl border border-[#2A2A2A] bg-[#0A0A0A] px-3 py-3 text-sm text-[#A0A0A0] file:mr-3 file:rounded-lg file:border-0 file:bg-[#2A2A2A] file:px-3 file:py-2 file:text-xs file:font-semibold file:text-[#F5F5F5]"
        />
        <button
          type="submit"
          class="h-12 shrink-0 whitespace-nowrap rounded-xl bg-[#F5F0E8] px-5 text-sm font-semibold text-[#0A0A0A] transition hover:bg-[#E8E0D0] sm:min-w-[9.5rem]"
          >Upload Addon</button
        >
      </form>
    </article>

    <article class="rounded-2xl border border-[#2A2A2A] bg-[#1A1A1A] p-5 sm:p-6">
      <h3 class="text-sm font-semibold text-[#F5F5F5]">Resource Pack</h3>
      <div class="mt-3 overflow-x-auto rounded-xl border border-[#2A2A2A]">
        <table class="min-w-full divide-y divide-[#2A2A2A] text-left text-sm">
          <thead class="bg-[#111111] text-[#A0A0A0]">
            <tr>
              <th class="px-4 py-3">Nama</th>
              <th class="px-4 py-3">Versi</th>
              <th class="px-4 py-3">Status</th>
              <th class="px-4 py-3">Aksi</th>
            </tr>
          </thead>
          <tbody id="resource-pack-table" class="divide-y divide-[#2A2A2A] bg-[#0A0A0A]"></tbody>
        </table>
      </div>
    </article>

    <article class="rounded-2xl border border-[#2A2A2A] bg-[#1A1A1A] p-5 sm:p-6">
      <h3 class="text-sm font-semibold text-[#F5F5F5]">Behavior Pack</h3>
      <div class="mt-3 overflow-x-auto rounded-xl border border-[#2A2A2A]">
        <table class="min-w-full divide-y divide-[#2A2A2A] text-left text-sm">
          <thead class="bg-[#111111] text-[#A0A0A0]">
            <tr>
              <th class="px-4 py-3">Nama</th>
              <th class="px-4 py-3">Versi</th>
              <th class="px-4 py-3">Status</th>
              <th class="px-4 py-3">Aksi</th>
            </tr>
          </thead>
          <tbody id="behavior-pack-table" class="divide-y divide-[#2A2A2A] bg-[#0A0A0A]"></tbody>
        </table>
      </div>
    </article>
  </section>

  <script>
    const feedback = document.getElementById("feedback");
    const resourcePackTable = document.getElementById("resource-pack-table");
    const behaviorPackTable = document.getElementById("behavior-pack-table");

    type FeedbackType = "info" | "success" | "error";
    type PackType = "resource" | "behavior";
    type PackItem = {
      id: string;
      name: string;
      version: string;
      type: PackType;
      folder: string;
      enabled: boolean;
    };

    function showFeedback(message: string, type: FeedbackType = "info") {
      if (!(feedback instanceof HTMLElement)) {
        return;
      }
      feedback.classList.remove("hidden", "text-[#A0A0A0]", "text-[#ff9e9e]", "text-[#F5F0E8]");
      feedback.classList.add(type === "error" ? "text-[#ff9e9e]" : type === "success" ? "text-[#F5F0E8]" : "text-[#A0A0A0]");
      feedback.textContent = message;
    }

    async function api<T>(url: string, options: RequestInit = {}): Promise<T> {
      const response = await fetch(url, options);
      const data = (await response.json()) as { message?: string } & T;
      if (!response.ok) {
        throw new Error(data.message || "Request gagal");
      }
      return data;
    }

    async function togglePack(type: PackType, pack: PackItem, enabled: boolean) {
      await api<{ ok: boolean }>("/api/packs/toggle", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          type,
          packId: pack.id,
          version: pack.version,
          enabled,
        }),
      });
    }

    async function deletePack(type: PackType, pack: PackItem) {
      await api<{ ok: boolean }>("/api/packs/delete", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ type, packId: pack.id }),
      });
    }

    function renderRows(target: HTMLElement, packs: PackItem[], type: PackType) {
      target.innerHTML = "";

      if (!packs.length) {
        target.innerHTML = '<tr><td colspan="4" class="px-4 py-4 text-center text-[#666666]">Belum ada addon.</td></tr>';
        return;
      }

      for (const pack of packs) {
        const row = document.createElement("tr");
        row.className = "text-[#F5F5F5]";

        const statusText = pack.enabled ? "ON" : "OFF";
        const toggleText = pack.enabled ? "OFF" : "ON";
        const toggleClass = pack.enabled
          ? "rounded-lg border border-[#444444] bg-[#2A2A2A] px-3 py-1 text-xs font-semibold text-[#F5F5F5] transition hover:bg-[#444444]"
          : "rounded-lg bg-[#F5F0E8] px-3 py-1 text-xs font-semibold text-[#0A0A0A] transition hover:bg-[#E8E0D0]";

        row.innerHTML = `
          <td class="px-4 py-3">${pack.name}</td>
          <td class="px-4 py-3">${pack.version}</td>
          <td class="px-4 py-3">${statusText}</td>
          <td class="px-4 py-3">
            <div class="flex flex-wrap gap-2">
              <button data-action="toggle" class="${toggleClass}">${toggleText}</button>
              <button data-action="delete" class="rounded-lg border border-[#444444] bg-[#2A2A2A] px-3 py-1 text-xs font-semibold text-[#F5F5F5] transition hover:bg-[#444444]">Hapus</button>
            </div>
          </td>
        `;

        row.querySelector('[data-action="toggle"]')?.addEventListener("click", async () => {
          try {
            showFeedback("Mengubah status addon...");
            await togglePack(type, pack, !pack.enabled);
            await loadPacks();
            showFeedback("Status addon berhasil diubah.", "success");
          } catch (error) {
            showFeedback(error instanceof Error ? error.message : "Request gagal", "error");
          }
        });

        row.querySelector('[data-action="delete"]')?.addEventListener("click", async () => {
          if (!window.confirm(`Hapus addon ${pack.name}?`)) {
            return;
          }
          try {
            showFeedback("Menghapus addon...");
            await deletePack(type, pack);
            await loadPacks();
            showFeedback("Addon berhasil dihapus.", "success");
          } catch (error) {
            showFeedback(error instanceof Error ? error.message : "Request gagal", "error");
          }
        });

        target.appendChild(row);
      }
    }

    async function loadPacks() {
      const data = await api<{ resource: PackItem[]; behavior: PackItem[] }>("/api/packs");
      if (resourcePackTable instanceof HTMLElement) {
        renderRows(resourcePackTable, data.resource, "resource");
      }
      if (behaviorPackTable instanceof HTMLElement) {
        renderRows(behaviorPackTable, data.behavior, "behavior");
      }
    }

    document.getElementById("pack-upload-form")?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const input = document.getElementById("pack-file");
      if (!(input instanceof HTMLInputElement) || !input.files || !input.files[0]) {
        showFeedback("Pilih file .mcpack atau .mcaddon terlebih dahulu.", "error");
        return;
      }

      const form = new FormData();
      form.append("file", input.files[0]);

      try {
        showFeedback("Mengupload addon...");
        await api<{ ok: boolean }>("/api/packs", {
          method: "POST",
          body: form,
        });
        input.value = "";
        await loadPacks();
        showFeedback("Upload addon berhasil.", "success");
      } catch (error) {
        showFeedback(error instanceof Error ? error.message : "Request gagal", "error");
      }
    });

    loadPacks().catch((error) => {
      showFeedback(error instanceof Error ? error.message : "Request gagal", "error");
    });
  </script>
</DashboardShell>
